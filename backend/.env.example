# Copy to .env and fill in real values — never commit .env
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me-jwt
DATABASE_URL=sqlite:///data.db

# Comma-separated list of allowed frontend origins
# Dev default is already http://localhost:5173 when this var is unset
CORS_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app,chrome-extension://your-extension-id

# Internal extension auth + throttling
EXTENSION_BEARER_TOKEN=change-me-extension-token
EXTENSION_RATE_LIMIT=60
EXTENSION_RATE_WINDOW_SECONDS=60

# LLM enrichment for extension classification
GROQ_API_KEY=
LITELLM_MODEL=openai/gpt-oss-20b
# Optional if you run LiteLLM as a proxy service instead of direct SDK calls
LITELLM_BASE_URL=
